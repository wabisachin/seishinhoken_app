# === このファイルを .env にコピーして各キーを貼り付けてください ===
# （.env は .gitignore 済み。前処理スクリプトと開発サーバーが読み込みます）

# --- Supabase ---
# https://supabase.com/dashboard/account/tokens で発行（プロジェクト作成に使用）
SUPABASE_ACCESS_TOKEN=
# ↓の2つはプロジェクト作成後にこちらで自動設定します（空でOK）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- 埋め込み ---
# https://dashboard.voyageai.com/ で発行
VOYAGE_API_KEY=

# --- LLM（使うものだけでOK。まずはAnthropicだけで動きます） ---
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# --- デプロイ（あとで使用） ---
# https://vercel.com/account/settings/tokens
VERCEL_TOKEN=
