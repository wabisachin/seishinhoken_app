# Supabase（サーバー専用キー。クライアントに公開しない）
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# 埋め込み
VOYAGE_API_KEY=

# LLMプロバイダ（使うものだけ設定すればよい。どのモデルを使うかは管理者(/admin)がDBで設定する）
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=

# 管理者ページ（/admin）のログインパスワード。推測されにくい値を設定すること
ADMIN_PASSWORD=

# Vercel Cron専用の共有シークレット（/api/cron/topupの不正呼び出し防止）。ランダムな文字列でよい
CRON_SECRET=
